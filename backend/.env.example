# Copy this file to .env and fill in real values (do NOT commit secrets)
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/profile-branding

# JWT
JWT_SECRET=change_this_in_production
JWT_EXPIRE=7d

# GitHub API (optional)
GITHUB_TOKEN=

# Gemini API (optional)
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_API_KEY=

# AI Interview (LiveKit + Deepgram agent)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=

# Google Cloud Vision (optional)
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Python NLP Service
PYTHON_NLP_SERVICE_URL=http://localhost:8000

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Charters internal admin integration
CHARTERS_API_URL=http://localhost:5000
CHARTERS_API_URLS=
# Optional for local testing: if set in development, tunnel is tried first.
# Example: https://your-charters-tunnel.loca.lt
CHARTERS_API_TUNNEL_URL=
CHARTERS_ADMIN_LOGIN_PATHS=/api/v1/auth/login,/api/auth/login
CHARTERS_SERVICE_KEY=change_this_shared_service_key
CHARTERS_SERVICE_KEYS=
CHARTERS_API_TIMEOUT_MS=5000
CHARTERS_API_RETRY_COUNT=2
CHARTERS_API_RETRY_DELAY_MS=200
CHARTERS_LOGIN_RETRY_COUNT=1
# Local fallback for admin candidate endpoints when Charters upstream is unavailable.
# Default behavior in development is enabled even if this is blank.
# Set to true/false to force behavior explicitly.
CHARTERS_LOCAL_FALLBACK=true

# Shared internal auth for acting-admin token verification/signing
INTERNAL_SHARED_SECRET=change_this_internal_shared_secret
INTERNAL_ACTING_TOKEN_ISSUER=profile-branding
INTERNAL_ACTING_TOKEN_TTL=5m
INTERNAL_SERVICE_KEYS=

ADMIN_TOKEN_EXPIRE=15m
